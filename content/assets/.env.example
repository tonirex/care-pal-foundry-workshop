# Copy to .env and fill in. Never commit a real .env.
# The shared workshop project endpoint (Foundry portal -> project -> Overview -> Endpoint):
FOUNDRY_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>

# Model deployment name (Foundry portal -> Models + endpoints -> Name column).
# Default keeps everyone moving instead of choosing models.
FOUNDRY_MODEL_NAME=model-router

# Your initials -> agents are named carepal-<initials> in the shared project.
INITIALS=xx
